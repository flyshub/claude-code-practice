---
// src/layouts/BlogPost.astro
// 文章页布局：接收 title/description/pubDate，正文通过 <slot /> 注入（Astro 的地道写法）。
const { title, description, pubDate } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <main style="font-family: system-ui, sans-serif; max-width: 720px; margin: 2rem auto; padding: 0 1rem; line-height: 1.8;">
      <a href={import.meta.env.BASE_URL} style="color: #666; text-decoration: none;">← 回首页</a>
      <article style="margin-top: 1.5rem;">
        <h1 style="line-height: 1.3;">{title}</h1>
        <p style="color: #888; font-size: 0.9rem;">
          {pubDate.toLocaleDateString('zh-CN')}
        </p>
        <slot />
      </article>
    </main>
  </body>
</html>
